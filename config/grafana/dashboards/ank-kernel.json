    {
      "id": 10,
      "title": "LSM Policy Decisions by Decision",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(ank_lsm_policy_decisions_total{decision=\"allow\"}[1m]))",
          "legendFormat": "allow"
        },
        {
          "expr": "sum(rate(ank_lsm_policy_decisions_total{decision=\"deny\"}[1m]))",
          "legendFormat": "deny"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "stacking": { "mode": "none" },
            "axisCenteredZero": false
          },
          "mappings": []
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "deny" }, "properties": [{ "id": "color", "value": { "fixed": "red" } }] },
          { "matcher": { "id": "byName", "options": "allow" }, "properties": [{ "id": "color", "value": { "fixed": "green" } }] }
        ]
      }
    },
